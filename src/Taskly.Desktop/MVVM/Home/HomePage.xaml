<Page x:Class="Taskly.Desktop.MVVM.Home.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage">

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}" VerticalAlignment="Stretch">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch">
            <StackPanel Margin="60,60,60,80" VerticalAlignment="Top">
                <!-- Hero Section -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Text="Welcome to Taskly"
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        TextAlignment="Center"
                        Margin="0,0,0,10" />
                    <TextBlock
                        Text="Your Modern Task Management"
                        FontSize="20"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center" />
                </StackPanel>

                <!-- Main Description -->
                <TextBlock
                    Text="Organize your tasks efficiently with our intuitive application. Create, manage, categorize, and remind yourself to never miss anything."
                    FontSize="16"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    TextWrapping="Wrap"
                    MaxWidth="600"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,0,0,40" />

                <!-- Features Section -->
                <StackPanel Margin="0,0,0,40">
                    <TextBlock
                        Text="Features"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        Margin="0,0,0,12" />

                    <Grid MaxWidth="700" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Feature 1 -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="#00b4ef" FontSize="24"
                                               Margin="0,0,0,8" />
                                <TextBlock Text="Manage Tasks" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Create and track your tasks effortlessly." FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Feature 2 -->
                        <Border Grid.Row="0" Grid.Column="2"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="Tag24" Foreground="#00b4ef" FontSize="24" Margin="0,0,0,8" />
                                <TextBlock Text="Tags &amp; Categories" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Organize with tags and categories." FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Feature 3 -->
                        <Border Grid.Row="2" Grid.Column="0"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="Clock24" Foreground="#00b4ef" FontSize="24" Margin="0,0,0,8" />
                                <TextBlock Text="Reminders" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Get notifications for important tasks." FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Feature 4 -->
                        <Border Grid.Row="2" Grid.Column="2"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="Attach24" Foreground="#00b4ef" FontSize="24" Margin="0,0,0,8" />
                                <TextBlock Text="Attachments" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Add files to your tasks." FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- CTA Section -->
                <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Sign in to get started" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,0,0,16" />
                    <ui:Button x:Name="LoginButton" Content="Sign in with Auth0" FontSize="14" Padding="24,12,24,12"
                               Command="{Binding ViewModel.SignInCommand}" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>