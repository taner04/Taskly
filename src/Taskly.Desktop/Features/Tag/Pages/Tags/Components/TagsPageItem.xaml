<ui:Card
    x:Class="Taskly.Desktop.Features.Tag.Pages.Tags.Components.TagsPageItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root"
    Padding="16,12"
    mc:Ignorable="d">
    <ui:Card.Style>
        <Style BasedOn="{StaticResource {x:Type ui:Card}}" TargetType="ui:Card">
            <!--  Ensure solid background using the same technique as HomePage  -->
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <!--  Allow scroll events to pass through  -->
            <Setter Property="UIElement.IsHitTestVisible" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:Card.Style>
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            FontSize="18"
            FontWeight="Medium"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="{Binding TagName, ElementName=Root}" />

        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <ui:Button
                Width="42"
                Height="42"
                Margin="0,0,8,0"
                Padding="0"
                Appearance="Secondary"
                Command="{Binding EditCommand, ElementName=Root}"
                CommandParameter="{Binding DataContext, ElementName=Root}"
                FontSize="16"
                ToolTip="Edit Tag">
                <ui:SymbolIcon Symbol="Edit16" />
            </ui:Button>
            <ui:Button
                Width="42"
                Height="42"
                Padding="0"
                Appearance="Secondary"
                Command="{Binding DeleteCommand, ElementName=Root}"
                CommandParameter="{Binding DataContext, ElementName=Root}"
                FontSize="16"
                ToolTip="Delete Tag">
                <ui:SymbolIcon Symbol="Delete16" />
                <ui:Button.Style>
                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E81123" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
        </StackPanel>
    </Grid>
</ui:Card>