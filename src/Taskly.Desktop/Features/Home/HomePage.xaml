<Page
    x:Class="Taskly.Desktop.Features.Home.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Taskly.Desktop.Features.Home.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="HomePage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:PassiveScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,20,40,40">
            <StackPanel VerticalAlignment="Top" Background="Transparent">
                <!--  Hero Section  -->
                <ui:Card
                    x:Name="HeroCard"
                    Margin="0,0,0,24"
                    Padding="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="42"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="Welcome to Taskly" />
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="20"
                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Text="Unlock your full potential with organized workflows." />
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontSize="16"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Your modern task management for maximum productivity. Seamlessly manage your day, set goals, and achieve more."
                                TextWrapping="Wrap" />

                            <StackPanel Margin="0,32,0,0" Orientation="Horizontal">
                                <ui:Anchor
                                    Margin="0,0,16,0"
                                    Padding="24,12"
                                    Appearance="Primary"
                                    Content="GitHub"
                                    FontSize="16"
                                    Icon="ArrowRight24"
                                    NavigateUri="https://github.com/taner04/Taskly" />
                            </StackPanel>
                        </StackPanel>

                        <ui:SymbolIcon
                            Grid.Column="1"
                            Margin="40,0,0,0"
                            FontSize="140"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Opacity="0.3"
                            Symbol="ClipboardTask24" />
                    </Grid>
                </ui:Card>

                <TextBlock
                    Margin="4,0,0,20"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="Features at a glance" />

                <!--  Features Grid  -->
                <UniformGrid x:Name="FeaturesGrid" Columns="2">

                    <components:FeatureCard
                        Title="Manage Tasks"
                        Margin="0,0,8,16"
                        Description="Create and track your tasks effortlessly with priorities and status."
                        IconForeground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Symbol="CheckmarkCircle24" />

                    <components:FeatureCard
                        Title="Tags &amp; Categories"
                        Margin="8,0,0,16"
                        Description="Organize everything with flexible tags and various categories."
                        IconForeground="{DynamicResource SystemFillColorSuccessBrush}"
                        Symbol="Tag24" />

                    <components:FeatureCard
                        Title="Reminders"
                        Margin="0,0,8,16"
                        Description="Never miss a deadline again thanks to smart notifications."
                        IconForeground="{DynamicResource SystemFillColorCautionBrush}"
                        Symbol="Clock24" />

                    <components:FeatureCard
                        Title="Attachments"
                        Margin="8,0,0,16"
                        Description="Add important documents and files directly to your tasks."
                        IconForeground="{DynamicResource SystemFillColorAttentionBrush}"
                        Symbol="Attach24" />
                </UniformGrid>
            </StackPanel>
        </Grid>
    </ui:PassiveScrollViewer>
</Page>