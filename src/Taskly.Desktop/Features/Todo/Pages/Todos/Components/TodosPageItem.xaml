<ui:Card
    x:Class="Taskly.Desktop.Features.Todo.Pages.Todos.Components.TodosPageItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root"
    Padding="16,12"
    mc:Ignorable="d">
    <ui:Card.Style>
        <Style BasedOn="{StaticResource {x:Type ui:Card}}" TargetType="ui:Card">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="UIElement.IsHitTestVisible" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:Card.Style>
    <Expander
        x:Name="TodoExpander"
        Padding="16,8"
        HorizontalContentAlignment="Stretch"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        PreviewMouseLeftButtonDown="Expander_OnPreviewMouseLeftButtonDown">
        <Expander.Header>
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Medium"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Title, ElementName=Root}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button
                        Width="42"
                        Height="42"
                        Margin="0,0,8,0"
                        Padding="0"
                        Appearance="Secondary"
                        Command="{Binding EditCommand, ElementName=Root}"
                        CommandParameter="{Binding DataContext, ElementName=Root}"
                        FontSize="16"
                        ToolTip="Edit Todo">
                        <ui:SymbolIcon Symbol="Edit16" />
                    </ui:Button>
                    <ui:Button
                        Width="42"
                        Height="42"
                        Margin="0,0,8,0"
                        Padding="0"
                        Appearance="Secondary"
                        Command="{Binding DeleteCommand, ElementName=Root}"
                        CommandParameter="{Binding DataContext, ElementName=Root}"
                        FontSize="16"
                        ToolTip="Delete Todo">
                        <ui:SymbolIcon Symbol="Delete16" />
                        <ui:Button.Style>
                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#E81123" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Expander.Header>

        <StackPanel Margin="16,8,16,16">
            <TextBlock
                Margin="0,0,0,8"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Description" />
            <TextBlock
                Margin="0,0,0,16"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="{Binding Description, ElementName=Root}"
                TextWrapping="Wrap" />

            <!--  Tags  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Tags" />
            <ItemsControl Margin="0,0,0,16" ItemsSource="{Binding Tags, ElementName=Root}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card
                            Margin="0,0,4,4"
                            Padding="8,4"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <TextBlock FontSize="12" Text="{Binding Name}" />
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Attachments  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Attachments" />
            <ItemsControl ItemsSource="{Binding Attachments, ElementName=Root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Margin="0,0,8,0" Symbol="Document24" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding FileName}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Expander>
</ui:Card>